// Waybar Configuration

{
    "spacing": 2,
    "layer": "top",
    "width": -10,

    "modules-left": [
        "hyprland/workspaces",
        "hyprland/submap", 
        "hyprland/window"
    ],
    "modules-center": ["clock"],
    "modules-right": [
        "tray", 
        "idle_inhibitor",
        "memory",
        "network",
        "backlight",
        "pulseaudio",
        "custom/microphone",
        "battery"
    ],

    // ----------------------------------------- //
    // ------- // Modules Configuration //------ //
    // ----------------------------------------- //
    
    "hyprland/workspaces": {
        "format": "{icon}ï„… {windows} îک،",
        "format-window-separator": "  ",
        "window-rewrite-default": "َ±ƒ¼",
        "window-rewrite": {
            "1Password": "ï“¼",
            "Alacritty": "ï’‰",
            "Vivaldi": "َ°‡§",
            "Code": "َ°¨‍",
            "discord": "َ°™¯",
            "pavucontrol": "îک¸",
            "Brave": "ïˆ›",
            "Noisetorch": "ï„°",
            "Obsidian": "ï’ٹ"
        },
    },

    "hyprland/submap": {
        "format": "îک، َ°،± : <span style=\"italic\">{}</span> îک،",
        "max-length": 50
    },

    "hyprland/window": {
        "format": "{}",
        "min-length": 30,
        "max-length": 30,
        "rewrite": {
            "(.*) - Vivaldi":"َ°‡§ $1",
            "(.*) - Visual Studio Code": "َ°¨‍ $1",
            "(.*) - Discord":"َ°™¯ $1",
            "(.*) - 1Password":"ï“¼ $1",
            "(.*) - Brave":"ïˆ› $1",
            "(.*) - Noisetorch":"ï„° $1",
            "(.*) - Obsidian":"ï’ٹ $1"
        }
    },

    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 32,
        "icon-theme": "",
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },
    
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated":"َ°ˆˆ",
            "deactivated":"َ°ˆ‰"
        }
    },

    "tray": {
        "icon-size": 16,
        "spacing": 5
    },

    "clock": {
        "interval": 1,
        "format": "{:%H:%M:%S}  ",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}  "
    },

    "network": {
        "format-wifi": "َ°–©",
        "format-ethernet": "َ°ˆ€",
        "format-linked": "ïƒپ",
        "format-disconnected": "ï„§",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}\n{essid} {signalStrength}%",
        "interval": 5
    },
    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "َ°‌ں",
        "format-bluetooth": "{icon}",
        "format-bluetooth-muted": "َ°‌ں",
        "format-source": "{icon}",
        "format-source-muted": "َ°‌ں",
        "format-icons": {
            "headphone": ["", "", "", "", "", "", "", "", "", "", ""],
            "hands-free": "َ±،ڈ",
            "headset": ["َ°‹ژ", "َ°‹ژ", "َ°‹ژ", "َ°‹ژ", "َ°‹ژ", "َ°‹ژ", "َ°‹ژ", "َ°‹ژ", "َ°‹ژ", "َ°‹ژ", "َ°‹ژ"],
            "phone": "",
            "portable": "َ°†،",
            "car": "َ°„‹",
            "default": ["َ°•؟", "َ°•؟", "َ°–€", "َ°–€", "َ°–€", "َ°–€", "َ°•¾", "َ°•¾", "َ°•¾", "َ°•¾", "َ°•¾"]
        },
        "tooltip-format": "{desc}\nVolume: {volume}%",
        "on-click": "pavucontrol",
        "on-scroll-up": "pamixer -i 5",
        "on-scroll-down": "pamixer -d 5",
        "scroll-step": 5,
        "smooth-scrolling-threshold": 1,
        "reverse-scrolling": false,
        "ignored-sinks": [],
        "max-volume": 150
    },
    "battery": {
        "bat": "BAT0",
        "interval": 10,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}",
            "format-charging": "{icon}َ±گ‹",
            "format-plugged": "{icon}",
            "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½","َ°‚€", "َ°‚پ", "َ°پ¹"],
        "tooltip-format": "{timeTo}, {capacity}%"
    },

    "backlight": {
        "device": "amdgpu_bl1",
        "format": "{icon}",
        "format-icons": ["َ°ƒ‍", "َ°ƒں", "َ°ƒ "],
        "tooltip-format": "Brightness: {percent}%"
    },

    "memory": {
        "interval": 5,
        "format": "{}% î؟…",
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G"
    },

    "custom/microphone": {
        "exec": "pamixer --default-source --get-mute | grep -q true && echo 'َ°چ­' || echo 'َ°چ¬'",
        "interval": 1,
        "tooltip": false,
        "on-click": "pamixer --default-source -t",
        "format": "{}"
    }
}
